{
    "name": "drupal-composer/drupal-project",
    "description": "Project template for GT branded Drupal 11",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "authors": [
        {
            "name": "IC Webteam",
            "email": "webteam@gatech.edu",
            "role": "Makers of things like this"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "https://github.gatech.edu/ICWebTeam/gt_profile.git"
        },
        {
            "type": "vcs",
            "url": "https://github.gatech.edu/ICWebTeam/gt_theme.git"
        },
        {
            "type": "vcs",
            "url": "https://github.gatech.edu/ICWebTeam/gt_tools.git"
        },
        {
            "type": "vcs",
            "url": "https://github.gatech.edu/ICWebTeam/hg_reader.git"
        }
    ],
    "require": {
        "composer/installers": "^1.2",
        "cweagans/composer-patches": "^1.6.5",
        "drupal/admin_toolbar": "^3.0",
        "drupal/back_to_top": "^3.0",
        "drupal/better_exposed_filters": "^7.0",
        "drupal/block_region_permissions": "^1.6",
        "drupal/cas": "^3.0@beta",
        "drupal/colorbox": "^2.0",
        "drupal/core-composer-scaffold": "^11.0",
        "drupal/core-project-message": "^11.0",
        "drupal/core-recommended": "^11.0",
        "drupal/ctools": "^4.0",
        "drupal/devel": "^5.0",
        "drupal/easy_breadcrumb": "^2.0",
        "drupal/entity_reference_revisions": "^1.10",
        "drupal/externalauth": "^2.0",
        "drupal/faqfield": "^8.0",
        "drupal/field_formatter_class": "^1.5",
        "drupal/field_group": "^3.0",
        "drupal/focal_point": "^2.0@alpha",
        "drupal/google_tag": "^2.0",
        "drupal/image_field_caption": "^3.0",
        "drupal/imce": "^3.0",
        "drupal/jquery_ui_accordion": "^2.0",
        "drupal/jquery_ui_datepicker": "^2.0",
        "drupal/jquery_ui_slider": "^2.0",
        "drupal/layout_builder_iframe_modal": "^1.3",
        "drupal/layout_builder_modal": "^1.0",
        "drupal/layout_builder_restrictions": "^3.0",
        "drupal/masquerade": "^2.0@beta",
        "drupal/metatag": "^2.1",
        "drupal/module_filter": "^5.0",
        "drupal/paragraphs": "^1.10",
        "drupal/pathauto": "^1.10",
        "drupal/pathologic": "^2.0@alpha",
        "drupal/redirect": "^1.10",
        "drupal/search404": "^2.0",
        "drupal/social_media_links": "^2.6",
        "drupal/stable": "^2.0",
        "drupal/token": "^1.6",
        "drupal/twig_xdebug": "^1.2",
        "drupal/upgrade_status": "^4.0",
        "drupal/video_embed_field": "^3.0@alpha",
        "drupal/view_unpublished": "^1.0",
        "drupal/views_accordion": "^2.0",
        "drupal/webform": "^6.0",
        "drupal/xmlsitemap": "^2.0@beta",
        "drush/drush": "^13.0",
        "gt/gt_profile": "^5.0",
        "gt/gt_theme": "^5.0",
        "gt/gt_tools": "^5.0",
        "gt/hg_reader": "^5.0",
        "vlucas/phpdotenv": "^2.4",
        "webflo/drupal-finder": "^1.0.0",
        "webmozart/path-util": "^2.3"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/console-extend-plugin": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true
        }
    },
    "extra": {
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/{$name}": [
                "type:drupal-drush"
            ]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "web"
            }
        }
    }
}
